<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Rewards - Layali Café</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body{
  margin:0;
  font-family:Inter;
  background:#fbfbfb;
  display:flex;
  justify-content:center;
  align-items:center;
  min-height:100vh;
}

.container{
  width:450px;
  background:white;
  padding:30px;
  border:1px solid #eee;
  box-shadow:0 10px 30px rgba(0,0,0,0.05);
  text-align:center;
}

h1{
  font-family:'Cormorant Garamond';
  margin-bottom:10px;
}

.card{
  background:#fafafa;
  border:1px solid #eee;
  padding:20px;
  margin-top:15px;
}

.level{
  font-size:20px;
  font-weight:bold;
}

.bar{
  width:100%;
  height:10px;
  background:#eee;
  margin:10px 0;
  border-radius:20px;
  overflow:hidden;
}

.fill{
  height:100%;
  width:0%;
  background:#111;
  transition:0.5s;
}

button{
  margin-top:15px;
  width:100%;
  padding:12px;
  border:none;
  background:#111;
  color:white;
  cursor:pointer;
}

.perks{
  text-align:left;
  margin-top:15px;
  font-size:14px;
  color:#444;
}
</style>
</head>

<body>

<div class="container">
  <h1>Your Rewards ☕✨</h1>

  <p>Track your café journey & unlock perks</p>

  <div class="card">
    <div class="level" id="level">Member</div>

    <div class="bar">
      <div class="fill" id="fill"></div>
    </div>

    <p>Points: <b id="points">0</b></p>
  </div>

  <div class="card perks">
    <b>VIP Perks:</b>
    <ul>
      <li>☕ Free coffee after 500 points</li>
      <li>🍰 10% discount at Silver level</li>
      <li>🥇 Priority seating at Gold level</li>
      <li>✨ Exclusive seasonal drinks</li>
    </ul>
  </div>

  <button onclick="addPoints()">Simulate Purchase (+120 pts)</button>
</div>

<script>
let points = parseInt(localStorage.getItem("points")) || 0;

function updateUI(){
  document.getElementById("points").innerText = points;

  let level = "Member";
  let percent = (points % 500) / 5;

  if(points >= 1000){
    level = "Gold 🥇";
    percent = 100;
  }
  else if(points >= 500){
    level = "Silver 🥈";
    percent = 70;
  }
  else if(points >= 200){
    level = "Bronze 🥉";
    percent = 40;
  }

  document.getElementById("level").innerText = level;
  document.getElementById("fill").style.width = percent + "%";
}

function addPoints(){
  points += 120;
  localStorage.setItem("points", points);
  updateUI();
}

updateUI();
</script>

</body>
</html>
