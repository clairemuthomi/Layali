<section class="filter-menu">
  <h2>Explore Menu</h2>

  <div class="filters">
    <button onclick="filterMenu('all')">All</button>
    <button onclick="filterMenu('coffee')">Coffee</button>
    <button onclick="filterMenu('tea')">Tea</button>
    <button onclick="filterMenu('dessert')">Dessert</button>
  </div>

  <div class="items">

    <div class="item coffee">
      <h3>Espresso Noir</h3>
    </div>

    <div class="item tea">
      <h3>Mint Green Tea</h3>
    </div>

    <div class="item dessert">
      <h3>Vanilla Cheesecake</h3>
    </div>

  </div>
</section>

<script>
function filterMenu(type) {
  let items = document.querySelectorAll(".item");

  items.forEach(item => {
    if (type === "all") {
      item.style.display = "block";
    } else {
      item.style.display = item.classList.contains(type) ? "block" : "none";
    }
  });
}
</script>

<style>
.filter-menu {
  padding: 100px 60px;
  text-align: center;
}

.filters button {
  margin: 10px;
  padding: 10px 15px;
  border: 1px solid #ccc;
  background: white;
  cursor: pointer;
  border-radius: 20px;
}

.filters button:hover {
  background: #111;
  color: white;
}

.items {
  margin-top: 40px;
}

.item {
  padding: 20px;
  margin: 10px auto;
  width: 300px;
  background: #fafafa;
  border-radius: 12px;
}
</style>
